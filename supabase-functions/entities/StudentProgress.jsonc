{
  "name": "StudentProgress",
  "type": "object",
  "properties": {
    "student_email": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "grade": {
      "type": "string"
    },
    "resources_accessed": {
      "type": "number",
      "default": 0
    },
    "last_accessed": {
      "type": "string",
      "format": "date"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "student_email",
    "subject",
    "grade"
  ]
}